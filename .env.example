# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Groq Cloud API key — get yours at https://console.groq.com/keys
# Format: gsk_...
# Model used: llama-3.3-70b-versatile (configured in lib/grok.ts).
# When unset, the app falls back to a built-in stub reading so the UI still
# demos. The stub goes through the same safety filter as the real API.
EXPO_PUBLIC_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Legacy: the project previously used xAI Grok (xai-...). The old var name
# is still read as a fallback so existing .env files keep working, but
# please migrate to EXPO_PUBLIC_GROQ_API_KEY when you rotate.
# EXPO_PUBLIC_GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxx
